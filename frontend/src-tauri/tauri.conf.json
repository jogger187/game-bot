{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Game Bot",
  "version": "0.1.0",
  "identifier": "com.gamebot.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Game Bot - 遊戲自動化控制台",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": true,
      "scope": [
        {
          "name": "python-engine",
          "cmd": "python3",
          "args": true
        },
        {
          "name": "python",
          "cmd": "python",
          "args": true
        }
      ]
    },
    "fs": {
      "scope": {
        "allow": ["$APPDATA/**", "$RESOURCE/**", "**"]
      }
    }
  }
}
